{
    "custom/launcher": {
        "format": " \udb82\udcc7 ",
        "on-click": "~/.config/rofi/launchers/type-3/launcher.sh",
    },

    "hyprland/workspaces": {
        "all-outputs": true,
        "format-icons": {
            "urgent": "´ü¬",
            "active": "´åÆ",
            "default": "´äæ"
        },
        "format": "{icon}",
        "on-scroll-up": "hyprctl dispatch workspace e+1 1>/dev/null",
        "on-scroll-down": "hyprctl dispatch workspace e-1 1>/dev/null",
        "sort-by-number": true,
        "active-only": false,
    },

    "hyprland/window": {
        "icon": false,
        "separate-outputs": true,
    },

    "temperature#cpu": {
        "interval": 1,
        "hwmon-path": "/sys/devices/pci0000:00/0000:00:18.3/hwmon/hwmon0/temp1_input",
        "critical-threshold": 80,
        "format-critical": "{temperatureC}┬░C ´ïç",
        "format": "{temperatureC}┬░C ´ïë",
        "tooltip": true,
        "tooltip-format": "CPU",
    },

    "temperature#gpu": {
        "interval": 1,
        "hwmon-path": "/sys/devices/pci0000:00/0000:00:01.1/0000:01:00.0/0000:02:00.0/0000:03:00.0/hwmon/hwmon3/temp1_input",
        "critical-threshold": 80,
        "format-critical": "{temperatureC}┬░C ´ïç",
        "format": "{temperatureC}┬░C ´ïë",
        "tooltip": true,
        "tooltip-format": "GPU",
    },

    "disk": {
        "format": "´éá {specific_free:0.2f} GB",
        "unit": "GB",
    },

    "network": {
        "interface": "enp6s0",
        "interval": 2,
        "format-ethernet": "´é¬ {bandwidthUpBytes} ´é½ {bandwidthDownBytes}",
        "format-disconnected": "¾░▓ø Disconnected"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "¯╗¿ Muted",
        "format-icons": {
            "alsa_output.usb-Macronix_Razer_Barracuda_X_2.4_1234-00.analog-stereo": "´ÇÑ",
            "alsa_output.usb-Macronix_Razer_Barracuda_X_2.4_1234-00.analog-stereo-muted": "¯╗¿ ´ÇÑ",
            "headset": "´ÇÑ",
            "default": ["´Çº", "´Ç¿"]
        },
        "on-click": "pavucontrol"
    },

    "clock": {
        "format": "¾░Ñö {:%I:%M %p}",
        "format-alt": "´ü│ {:%A %B %d, %Y }",
        "interval": 1,
        "timezone": "America/Costa_Rica",
        "tooltip": false,
    },

    "tray": {
        "spacing": 10
    },

    "group/group-power": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 500,
            "children-class": "not-power",
            "transition-left-to-right": false,
        },
        "modules": [
            "custom/lock",
            "custom/power",
            "custom/reboot",
            "custom/quit",
        ]
    },
    "custom/lock": {
        "format": "¾░ìü",
        "tooltip": false,
        "on-click": "hyprlock"
    },
    "custom/quit": {
        "format": "¾░ù╝",
        "tooltip": false,
        "on-click": "hyprctl dispatch exit"
    },
    "custom/reboot": {
        "format": "¾░£ë",
        "tooltip": false,
        "on-click": "reboot"
    },
    "custom/power": {
        "format": "´Çæ",
        "tooltip": false,
        "on-click": "shutdown now"
    }
}
