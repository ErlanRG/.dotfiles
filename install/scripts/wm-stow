#!/usr/bin/env bash

set -eo pipefail

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &>/dev/null && pwd)
PROJECT_ROOT=$(dirname "$(dirname "$SCRIPT_DIR")")

usage() {
    cat <<EOF
Usage: $(basename "$0") <stow|unstow> [wm_name|all]

Examples:
    $(basename "$0") stow all        Stow core and all window managers
    $(basename "$0") unstow all      Unstow core and all window managers
EOF
}

ACTION=$1
TARGET=${2:-all}

if [ -z "$ACTION" ]; then
    usage
    exit 1
fi

case "$ACTION" in
    stow|unstow) ;;
    *)
        echo "Error: Invalid action '$ACTION'. Use 'stow' or 'unstow'."
        usage
        exit 1
        ;;
esac

CORE_DIR="$PROJECT_ROOT/core"

stow_action() {
    local dir="$1"
    local label="$2"
    local flag=""

    [ "$ACTION" = "unstow" ] && flag="-D"

    cd "$dir" || exit
    echo "${ACTION}ing $label..."
    stow $flag -t "$HOME" -v */
    echo "${ACTION}ing $label completed."
    echo ""
}

DIRS=("$CORE_DIR:core packages")

if [ "$TARGET" = "all" ]; then
    for wm in "$PROJECT_ROOT/wms"/*/; do
        [ -d "$wm" ] && DIRS+=("${wm%/}:$(basename "$wm")")
    done
else
    WM_DIR="$PROJECT_ROOT/wms/$TARGET"
    if [ ! -d "$WM_DIR" ]; then
        echo "Error: Window manager '$TARGET' not found in '$PROJECT_ROOT/wms'."
        exit 1
    fi
    DIRS+=("$WM_DIR:$TARGET")
fi

for entry in "${DIRS[@]}"; do
    dir="${entry%%:*}"
    label="${entry#*:}"
    stow_action "$dir" "$label"
done
