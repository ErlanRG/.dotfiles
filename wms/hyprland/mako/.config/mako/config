# ── Global ──
max-history=5
sort=+time

# ── Bindings ──
on-button-left=invoke-default-action
on-button-middle=dismiss-group
on-button-right=dismiss
on-touch=invoke-default-action
on-notify=exec mpv /usr/share/sounds/freedesktop/stereo/message.oga

# ── Typography ──
font=Iosevka NFM Medium 10
markup=1

format=<span foreground="#cba6f7"><b>%s</b></span>\n<span foreground="#bac2de">%b</span>
text-alignment=left

# ── Style ──
background-color=#1e1e2ef2
text-color=#cdd6f4
width=320
padding=12
margin=8
outer-margin=6
border-size=1
border-color=#45475a
border-radius=8
progress-color=over #313244

# ── Icons ──
icons=1
max-icon-size=28
icon-location=left

# ── Behavior ──
actions=1
history=1
default-timeout=6000
ignore-timeout=0
max-visible=5
layer=top
anchor=top-right

# ── Urgency: Low ──
[urgency=low]
border-color=#89b4fa

# ── Urgency: Normal ──
[urgency=normal]
border-color=#cba6f7

# ── Urgency: Critical ──
[urgency=critical]
border-color=#f38ba8
