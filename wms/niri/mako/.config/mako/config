# [ Global Config ]
max-history=5
sort=+time

# [ BINDING OPTIONS ]
on-button-left=invoke-default-action
on-button-middle=dismiss-group
on-button-right=dismiss
on-touch=invoke-default-action
on-notify=exec mpv /usr/share/sounds/freedesktop/stereo/message.oga

# [ STYLE OPTIONS ]
font=Iosevka NFM 11

# Catppuccin Mocha Glass
background-color=#1e1e2e99
text-color=#cdd6f4

# Layout
width=320
padding=14
margin=10
outer-margin=10

# Border
border-size=1
border-color=#cdd6f40c
border-radius=12

# Progress bar
progress-color=over #31324499

# Icons
icons=1
max-icon-size=36
icon-location=left

# Behavior
actions=1
history=1
format=<span foreground="#7aa2f7"><b>%s</b></span>\n<span foreground="#a9b1d6">%b</span>
text-alignment=left

default-timeout=8000
ignore-timeout=0

max-visible=5
layer=overlay
anchor=top-right

[urgency=critical]
border-color=#f38ba855
