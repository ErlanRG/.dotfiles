{
    "include": [ "modules-common.json" ],

    "ext/workspaces": {
        "format": "{icon}",
        "ignore-hidden": true,
        "on-click": "activate",
        "on-click-right": "deactivate",
        "sort-by-id": true,
    },

    "dwl/window": {
        "format": "[{layout}] {title}",
    },

    "custom/kbd": {
        "exec": "~/.config/waybar/scripts/keyboard-layout.sh",
        "return-type": "json",
        "format": "󰌌 {text}",
        "restart-interval": 0.5,
    },
}
