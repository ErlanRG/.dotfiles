{
    "layer": "top",
    "position": "top",
    "margin-top": 2,
    "margin-bottom": 0,
    "spacing": 0,

    "include": [ "~/.config/waybar/modules.json" ],

    "modules-left": [ "custom/launcher", "ext/workspaces", "dwl/window" ],
    "modules-center": [  "cpu", "memory", "disk", "network", "temperature#cpu", "temperature#gpu" ],
    "modules-right": [ "backlight", "battery", "pulseaudio", "tray", "clock", "custom/exit" ],
}
